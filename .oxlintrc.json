{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "env": {
    "node": true,
    "browser": true,
    "es2024": true
  },
  "ignorePatterns": [
    "dist/**",
    ".swarm/**",
    ".swarm-worktrees/**"
  ],
  "rules": {
    "no-console": "off",
    "typescript/no-explicit-any": "warn"
  }
}
