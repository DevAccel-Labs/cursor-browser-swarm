{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cursor-browser-swarm.local/schemas/context-packet.schema.json",
  "title": "ReactGrab Context Packet",
  "type": "object",
  "required": ["version", "route"],
  "properties": {
    "version": { "const": "0.1" },
    "route": { "type": "string", "minLength": 1 },
    "componentStack": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "sourceFiles": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "dom": { "type": "string" },
    "bbox": {
      "type": "object",
      "required": ["x", "y", "width", "height"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "width": { "type": "number", "exclusiveMinimum": 0 },
        "height": { "type": "number", "exclusiveMinimum": 0 }
      },
      "additionalProperties": false
    },
    "screenshotPath": { "type": "string" },
    "notes": { "type": "string" }
  },
  "additionalProperties": false
}
