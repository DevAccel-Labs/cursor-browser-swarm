{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cursor-browser-swarm.local/schemas/context-packet.schema.json",
  "title": "ReactGrab Context Packet",
  "type": "object",
  "required": ["version", "route"],
  "properties": {
    "version": { "const": "0.1" },
    "route": { "type": "string", "minLength": 1 },
    "intent": { "type": "string", "minLength": 1 },
    "componentStack": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "sourceFiles": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "target": {
      "type": "object",
      "properties": {
        "role": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "text": { "type": "string", "minLength": 1 },
        "selector": { "type": "string", "minLength": 1 },
        "testId": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "dom": { "type": "string" },
    "accessibilitySnapshot": { "type": "string" },
    "nearbyText": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "bbox": {
      "type": "object",
      "required": ["x", "y", "width", "height"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "width": { "type": "number", "exclusiveMinimum": 0 },
        "height": { "type": "number", "exclusiveMinimum": 0 }
      },
      "additionalProperties": false
    },
    "screenshotPath": { "type": "string" },
    "relatedArtifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "kind": {
            "enum": ["screenshot", "console", "network", "trace", "report", "other"]
          },
          "note": { "type": "string" }
        },
        "additionalProperties": false
      },
      "default": []
    },
    "preconditions": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "observations": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "debugHints": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "notes": { "type": "string" }
  },
  "additionalProperties": false
}
